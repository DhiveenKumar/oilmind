# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-name.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key-here
AZURE_SEARCH_INDEX=oilmind-index

# Azure Key Vault
AZURE_KEYVAULT_URL=https://your-keyvault-name.vault.azure.net/

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string-here